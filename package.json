{
  "name": "@inneropen/marvin-mcp",
  "version": "1.0.0-next.1",
  "description": "Official Model Context Protocol server for Marvin CMS.",
  "type": "module",
  "bin": {
    "marvin-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "test": "vitest run",
    "inspect": "npx @modelcontextprotocol/inspector npm run dev"
  },
  "keywords": [
    "marvin",
    "cms",
    "mcp",
    "model-context-protocol"
  ],
  "author": {
    "name": "InnerOpen"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/InnerOpen/marvin-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/InnerOpen/marvin-mcp/issues"
  },
  "homepage": "https://github.com/InnerOpen/marvin-mcp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inneropen/marvin-sdk": "^3.2.0-next.24",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^24.0.14",
    "eslint": "^9.31.0",
    "prettier": "^3.6.2",
    "semantic-release": "^25.0.8",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0",
    "vitest": "^3.2.4"
  }
}
